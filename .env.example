# =============================================================================
# Sovereign Edge — environment variable template
# Copy to .env and fill in real values before starting the stack.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — bot will not function without these
# ---------------------------------------------------------------------------

# Your Telegram bot token from @BotFather
SE_TELEGRAM_BOT_TOKEN=

# Numeric Telegram chat ID of the owner (only this user can interact with the bot).
# Get yours: message @userinfobot or check the Telegram API.
SE_TELEGRAM_OWNER_CHAT_ID=

# ---------------------------------------------------------------------------
# Cloud LLM API keys (optional — leave blank to use local Ollama only)
# ---------------------------------------------------------------------------

# Groq Cloud — fast inference for Llama/Mixtral; free tier available
SE_GROQ_API_KEY=

# Google Gemini — Flash / Pro via AI Studio; free tier available
SE_GOOGLE_API_KEY=

# Cerebras — ultra-fast inference; requires account at cerebras.ai
SE_CEREBRAS_API_KEY=

# Mistral — mistral-small / mistral-large via La Plateforme
SE_MISTRAL_API_KEY=

# ---------------------------------------------------------------------------
# Search / grounding
# ---------------------------------------------------------------------------

# Jina AI Reader key — removes RPD cap on web grounding (jina.ai/reader)
SE_JINA_API_KEY=

# Alpha Vantage — financial data for career/intelligence agents
SE_ALPHA_VANTAGE_KEY=

# ---------------------------------------------------------------------------
# Rate limits (requests per minute) — tune to your plan tier
# ---------------------------------------------------------------------------
SE_GROQ_RPM=30
SE_GEMINI_RPM=15
SE_CEREBRAS_RPM=30
SE_MISTRAL_RPM=2

# ---------------------------------------------------------------------------
# Ollama (local LLM — used when cloud keys are absent or rate-limited)
# In Docker Compose, the ollama service is reachable at http://ollama:11434
# ---------------------------------------------------------------------------
SE_OLLAMA_HOST=http://ollama:11434
SE_EMBEDDING_MODEL=qwen3-embedding:0.6b
SE_LOCAL_LLM_MODEL=qwen3:0.6b

# ---------------------------------------------------------------------------
# File paths inside the container
# These match the Docker ENV defaults; override only if you change the volume mount.
# ---------------------------------------------------------------------------
SE_PROJECT_ROOT=/app
SE_SSD_ROOT=/app/data
SE_LANCEDB_PATH=/app/data/lancedb
SE_LOGS_PATH=/app/data/logs
SE_MODELS_PATH=/app/data/models

# ---------------------------------------------------------------------------
# Career squad targeting (optional — generic defaults used when unset)
# ---------------------------------------------------------------------------

# Geographic focus for job searches and career coaching
SE_CAREER_TARGET_LOCATION=your city or region

# Target job titles (comma-separated)
SE_CAREER_TARGET_ROLES=ML Engineer, AI Engineer, LLM Engineer

# Your differentiators to highlight in job applications (comma-separated)
# Example: GRPO fine-tuning, LangGraph agents, vLLM serving
SE_CAREER_DIFFERENTIATORS=

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------

# Enable voice processing (requires additional deps not in default image)
SE_VOICE_ENABLED=false

# Enable creative agent
SE_CREATIVE_ENABLED=true

# Verbose debug logging — set true only during development
SE_DEBUG_MODE=false

# ---------------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------------

# Hour (0-23) and minute (0-59) for the daily morning briefing
SE_MORNING_WAKE_HOUR=5
SE_MORNING_WAKE_MINUTE=0

# Timezone string (pytz format) — used for scheduling
SE_TIMEZONE=US/Central

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------

# Emit logs as JSON (set true in production for structured log aggregation)
LOG_JSON=false

# OTEL collector endpoint — leave blank to disable tracing export
OTEL_EXPORTER_OTLP_ENDPOINT=
