[Unit]
Description=Sovereign Edge Telegram Bot
Documentation=https://github.com/omnipotence-eth/sovereign-edge
After=network-online.target ollama.service
Wants=network-online.target
PartOf=ai-stack.target

[Service]
Type=simple
User=omnipotence
WorkingDirectory=/home/omnipotence/sovereign-edge
Environment=SOPS_AGE_KEY_FILE=/home/omnipotence/.config/sops/age/keys.txt
EnvironmentFile=-/home/omnipotence/sovereign-edge/secrets/.env.decrypted

# Decrypt secrets — must use bash so the > redirect works
ExecStartPre=/bin/bash -c \
    'sops --decrypt --output-type dotenv /home/omnipotence/sovereign-edge/secrets/env.yaml \
     > /home/omnipotence/sovereign-edge/secrets/.env.decrypted \
     && chmod 600 /home/omnipotence/sovereign-edge/secrets/.env.decrypted'

ExecStart=/home/omnipotence/sovereign-edge/.venv/bin/python -m telegram_bot.bot
ExecStop=/bin/kill -TERM $MAINPID

Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sovereign-edge-telegram

# Resource limits — be a good citizen on 8 GB Jetson
MemoryMax=2G
CPUQuota=80%

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/home/omnipotence/sovereign-edge

[Install]
WantedBy=ai-stack.target
